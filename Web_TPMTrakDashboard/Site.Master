    <%-- Bajaj --%>
    <script>
        function SelectUnSelectAllCheckBox(element, gridId) {
            var tblRow = $('#' + gridId + ' tr');
            var thindex = $(element).closest('th').index();
            if ($(element).find("input").prop("checked")) {
                //for (var i = 1; i < tblRow.length; i++) {
                //    var td = tblRow[i].children[thindex];
                //    $(td).find('input').prop("checked", true);
                //}
                $(tblRow).find('td').children(thindex).find('input').prop('checked', true);
            }
            else {
                //for (var i = 1; i < tblRow.length; i++) {
                //    var td = tblRow[i].children[thindex];
                //    $(td).find('input').prop("checked", false);
                //}
                $(tblRow).find('td').children(1).find('input').prop('checked', false);
            }
        };
        function SetUnsetSelectAll(element, gridId) {
            let tblRow = $('#' + gridId + ' tr');
            let thindex = $(element).closest('td').index();
            let count = 0;
            //for (var i = 1; i < tblRow.length; i++) {
            //    var td = tblRow[i].children[thindex];
            //    if ($(td).find('input').prop("checked")) {
            //        count++;
            //    }
            //}
            count = $(tblRow).find('td').children(thindex).find("input[type='checkbox']:checked").length;
            let header = $('#' + gridId + ' tr th')[thindex];
            if (count == tblRow.length - 1) {
                $(header).find('input').prop("checked", true);
            }
            else {
                $(header).find('input').prop("checked", false);
            }
        }
        function SetControlValueNull(controlId) {
            $("#" + controlId).val("");
        }
        function openModal(modalid, isAnimationRequired) {
            $(".modal-backdrop").removeClass("modal-backdrop in");
            $("#" + modalid).modal('show');
            //if (isAnimationRequired.toLowerCase() == "true") {
            //    $('#' + modalid).addClass('show-modal');
            //} else {
            //    $('#' + modalid).removeClass('show-modal');
            //}
        }
        function openAddEditModals(modalid) {
            $(".modal-backdrop").removeClass("modal-backdrop in");
            storeModalDataBeforeChange(modalid, '');
            $('#' + modalid).modal('show');
            //$('#' + modalid).addClass('show-modal');
        };
        function toasterWarningMsg(msg, title) {
            toastr.options = {
                "closeButton": true,
                "debug": false,
                "newestOnTop": false,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "preventDuplicates": true,
                "onclick": null,
                "showDuration": "10000",
                "hideDuration": "10000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut",
                "toastClass": "toaster-position"
            }
            var d = Date();
            toastr.warning(msg, title);
            return false;
        }
        function openWarningModal_1(msg) {
            $("#lblWarningMessage").text(msg);
            $("#openWarningMessageModal").modal('show');
        }
        function openErrorModal_1(msg) {
            $('#errorMessageModal').modal('show');
            $('#lblErrorMessage').text(msg);
        }
        function clearAllModalScreen() {
            $(".modal-backdrop").removeClass("modal-backdrop in");
            $(".modal").modal("hide");
            $('body').removeClass('modal-open'); // after save/update records in popup, avoid scrollbar disapearing 
            return true;
        }
        function showSuccessMsg(msg, title) {
            debugger;
            toastr.options = {
                "closeButton": true,
                "debug": false,
                "newestOnTop": false,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "preventDuplicates": true,
                "onclick": null,
                "showDuration": "4000",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut",
                "toastClass": "toaster-position"
            }

            toastr['success'](msg, title);
            return false;
        }
        /*----------------------------- Cancelation Confirm---------------------------------------- */
        function storeModalDataBeforeChange(modalid, param) {
            var controlsValue = "";
            var inputControls = $('#' + modalid + ' .modal-body input');
            var multiLinrControls = $('#' + modalid + ' .modal-body textarea');
            var dropDownControls = $('#' + modalid + ' .modal-body select');
            for (var i = 0; i < inputControls.length; i++) {
                if (inputControls[i] != undefined) {
                    if (inputControls[i].type == "checkbox") {
                        controlsValue += inputControls[i].checked;
                    }
                    else {
                        controlsValue += inputControls[i].value;
                    }
                }
            }
            for (var i = 0; i < dropDownControls.length; i++) {
                if (dropDownControls[i] != undefined) {
                    controlsValue += dropDownControls[i].value;
                }
            }
            for (var i = 0; i < multiLinrControls.length; i++) {
                if (multiLinrControls[i] != undefined) {
                    controlsValue += multiLinrControls[i].value;
                }
            }
            controlsValue = controlsValue.replaceAll("/", "-");
            if (param == "compare") {
                if (controlsValue != $('#hdnModalValues').val()) {
                    $('#hdnModalIdToClose').val(modalid);
                    openCloseInsertEditModal('show');
                }
                else {
                    $('#' + modalid).modal('hide');
                }
            }
            else {
                $('#hdnModalValues').val(controlsValue);
            }
        }
        function openCloseInsertEditModal(action) {
            $("#insertUpdateCloseConfirmModal").modal(action);
        }
        function modalCloseYesClick() {
            $('#' + $('#hdnModalIdToClose').val()).modal('hide');
            openCloseInsertEditModal('hide');
            return false;
        }
        function openDeleteModal(modalid) {
            $("#" + modalid).modal('show');
        }
        /*-------- End Cancelation Confirm--------------------------------- */
        function freezeColumnFromLeft(tblId, freezColNo) {            let tblName = tblId;            let tblRow = $('[id$=' + tblName + '] > tbody > tr');            if (tblRow.length > 0) {                let rowth = tblRow[0].children;                var width = 0;                let columnCount = freezColNo;                for (var i = 0; i < columnCount; i++) {
                    let zindex = 800;
                    $("#" + tblName + " > tbody > tr > td:nth-child(" + (i + 1) + ")").css({
                        "position": "sticky", "left": width + "px", "z-index": (zindex - 1)
                    });
                    $("#" + tblName + "  > tbody > tr > th:nth-child(" + (i + 1) + ")").css({ "position": "sticky", "left": width + "px", "z-index": zindex });
                    width = width + (parseInt($(rowth[i]).css('width').replace('px', '')) - 2);
                }                $("#" + tblId + " > tbody > tr:first-child td:lt(" + columnCount + ")").css({ "z-index": "999" });            }        }
    </script>
