            function setPageScaleFactor() {
                //set scale factor
                var scaleFactor = 1.0;
                var orientation = "";
                if (screen.availHeight > screen.availWidth) {
                    orientation = "potrait";
                }
                else {
                    orientation = "landscape";
                }
                // Check the Windows display scale percentage
                if (window.devicePixelRatio >= 1.25 && orientation == "landscape") {
                    // Windows display scale is set to 150% or higher
                    scaleFactor = 0.8;
                }
                else if (window.devicePixelRatio >= 1.25 && orientation == "potrait") {
                    // Windows display scale is set to 150% or higher
                    scaleFactor = 0.6;
                }
                // Set the zoom level of the page
                document.body.style.zoom = scaleFactor;
            }
